# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# YOLO Model Configuration
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.5

# API Configuration
API_KEY=your-secret-key-change-in-production
CORS_ORIGINS=*

# Upload Configuration
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
