# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Environment Configuration (development, staging, production)
ENVIRONMENT=development
HTTPS_ENABLED=false

# Security Configuration
# CORS_ORIGINS format:
#   - Development: automatically set to localhost:3000, localhost:8000
#   - Staging: https://staging.example.com
#   - Production: https://app.example.com,https://android-app.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# YOLO Model Configuration
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.5

# API Configuration
API_KEY=your-secret-key-change-in-production

# Environmental APIs
# Get token from: https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# Upload Configuration
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads

# Database Configuration (Optional)
DATABASE_URL=sqlite:///./swv.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

